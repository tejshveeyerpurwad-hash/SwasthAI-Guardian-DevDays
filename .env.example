# ── SwasthAI Guardian — Environment Variables Template ───────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Backend
PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
GROQ_API_KEY=gsk_your_groq_api_key_here
AI_SERVICE_URL=http://localhost:8000

# CORS — comma-separated list of allowed frontend origins
# For local dev: http://localhost:5173
# For production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# Agentic Outbreak Monitor auth header
AGENT_SECRET=change_this_to_a_random_secret

# AI Service
# (GROQ_API_KEY and AGENT_SECRET are shared — set once above)
